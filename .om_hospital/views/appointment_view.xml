<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_appointment_form" model="ir.ui.view">
        <field name="name">hospital.appointment.form</field>
        <field name="model">hospital.appointment</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_confirm" type="object" string="Confirm" states="draft"
                        confirm="Are you sure you want to confirm the appointment?"
                        class="btn-primary" />
                    <button name="action_done" type="object" string="Mark As Done" states="confirm"
                        confirm="Are you sure you want to mark as done?"
                        class="btn-success" />
                    <button name="action_draft" type="object" string="Set To Draft" states="cancel"
                        confirm="Are you sure you want to reset to draft?"
                        class="btn-primary" />
                    <button name="action_cancel" type="object" string="Cancel"
                        states="draft,confirm,done"
                        confirm="Are you sure you want to cancel the appointment?"
                        class="btn-danger" />
                    <button name="action_url" type="object" string="Open URL" class="btn-primary" />
                    <field name="state" widget="statusbar" statusbar_visible="draft,done,confirm" />
                </header>
                <sheet>
                    <div class="ose_title">
                        <h1>
                            <field name="reference" readonly="1" />
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="patient_id" options="{'no_create_edit': True}"/>
                            <field name="patient_name_id" context="{'hide_code': True}"/>
                            <field name="name" />
                            <field name="age" />


                        </group>
                        <group>
                            <field name="doctor_id" options="{'no_open': True,'no_create': True}" />
                            <field name="gender" readonly="1" force_save="1" />
                            <field name="date_appointment" />
                            <field name="date_checkup" />
                            <!-- <field name="note" /> -->
                        </group>
                    </group>
                    <notebook>
                        <page string="Doctor Prescription" name="doctor_prescription">
                            <group>
                                <field name="prescription" />
                            </group>
                        </page>

                        <page string="Medicine" name="medicine">
                            <field name="prescription_line_ids">
                                <tree editable="bottom">
                                    <field name="name" />
                                    <field name="qty" />
                                </tree>
                                <form>
                                    <group>
                                        <group>
                                            <field name="name" />
                                        </group>
                                        <group>
                                            <field name="qty" />
                                        </group>
                                    </group>
                                </form>
                            </field>
                        </page>

                        <page string="Other Info" name="other_info">
                            <field name="note" />
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" />
                    <field name="activity_ids" />
                    <field name="message_ids" />
                </div>
            </form>
        </field>
    </record>

    <record id="view_appointment_tree" model="ir.ui.view">
        <field name="name">hospital.appointment.tree</field>
        <field name="model">hospital.appointment</field>
        <field name="arch" type="xml">
            <tree multi_edit="1">
                <header>
                    <button
                        name="action_done"
                        string="Mark As Done"
                        class="btn-primary"
                        type="object"
                    />
                </header>
                <field name="reference" />
                <field name="patient_id" />
                <field name="doctor_id" />
                <field name="age" optional="show" />
                <field name="gender" optional="show" />
                <field name="date_appointment" optional="show" />
                <field name="date_checkup" optional="hide" />
                <field name="note" optional="hide" />
                <field name="state" optional="hide" />
            </tree>
        </field>
    </record>

    <record id="view_appointment_kanban" model="ir.ui.view">
        <field name="name">hospital.appointment.kanban</field>
        <field name="model">hospital.appointment</field>
        <field name="arch" type="xml">
            <kanban>
                <!-- <field name="id" />
                <field name="patient_id" />
                <field name="gender" />
                <field name="date_appointment" />
                <field name="age" />
                <field name="note" /> -->
                <templates>
                    <t t-name="kanban-box">
                        <div t-attf-class="oe_kanban_global_click">
                            <div class="oe_kanban_details">
                                <ul>
                                    <li>Name: <field name="patient_id" /></li>
                                    <li>Doctor: <field name="doctor_id" /></li>
                                    <li>Age: <field name="age" /></li>
                                    <li>Gender: <field name="gender" /></li>
                                    <li>Appointment Date: <field name="date_appointment" /></li>
                                </ul>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_appointment_search" model="ir.ui.view">
        <field name="name">hospital.appointment.search</field>
        <field name="model">hospital.appointment</field>
        <field name="arch" type="xml">
            <search string="Appointments">
                <field name="patient_id" />
                <field name="note" />
                <separator />
                <filter string="Male" name="male" domain="[('gender', '=', 'male')]" />
                <filter string="Female" name="female" domain="[('gender', '=', 'female')]" />
                <filter string="Other" name="other" domain="[('gender', '=', 'other')]" />

                <group expand="1" string="Group By">
                    <filter string="Gender" name="gender" context="{'group_by':'gender'}" />
                    <filter string="Name" name="gender" context="{'group_by':'patient_id'}" />
                    <filter string="Appointment Date" name="date_appointment"
                        context="{'group_by':'date_appointment'}" />
                </group>
                <searchpanel>
                    <field name="gender" string="Gender" icon="fa-exchange" />
                    <field name="state" string="Status" select="multi" enable_counters="1" />
                </searchpanel>
            </search>
        </field>
    </record>

    <record id="action_hospital_appointment" model="ir.actions.act_window">
        <field name="name">Appointments</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">hospital.appointment</field>
        <field name="view_mode">tree,form,kanban</field>
        <field name="context">{}</field>
        <!-- <field name="context">{'search_default_gender': 1}</field> -->
        <field name="help" type="html">
            <p class="o_view_nocontent_empty_folder">
                Create your first appointment!
            </p>
        </field>
    </record>

    <record id="action_confirm_appointments" model="ir.actions.server">
        <field name="name">Confirm Appointment</field>
        <field name="type">ir.actions.server</field>
        <field name="model_id" ref="model_hospital_appointment" />
        <field name="binding_model_id" ref="model_hospital_appointment" />
        <field name="state">code</field>
        <field name="code">
            records.action_confirm()
        </field>
    </record>
   
</odoo>