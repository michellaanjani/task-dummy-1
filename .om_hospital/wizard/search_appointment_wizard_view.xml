<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <record id="view_search_appointment_wizard_form" model="ir.ui.view">
        <field name="name">search.appointment.wizard.form</field>
        <field name="model">search.appointment.wizard</field>
        <field name="arch" type="xml">
            <form string="Search Appointment">
                <group>
                    <field name="patient_id" />
                </group>
                <footer>
                    <button name="action_search_appointment_m1" string="Search Appointments (M1)"
                        type="object" class="btn-primary" />
                    <button name="action_search_appointment_m2" string="Search Appointments (M2)"
                        type="object" class="btn-primary" />
                    <button name="action_search_appointment_m3" string="Search Appointments (M3)"
                        type="object" class="btn-primary" />
                    <button string="Cancel" class="btn-secondary" special="cancel" />
                </footer>
            </form>
        </field>
    </record>

    <record id="action_search_appointment" model="ir.actions.act_window">
        <field name="name">Search Appointment</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">search.appointment.wizard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_search_appointment_wizard_form"></field>
        <field name="target">new</field>
        <!-- 
            ⭐⭐⭐ Line 25: TARGET = NEW ⭐⭐⭐
            - "new" → BUKA SEBAGAI POP-UP / DIALOG
            - "current" → buka di halaman yang sama (replace)
            - "inline" → embed di halaman
            - "fullscreen" → buka fullscreen
            
            ✅ INI YANG MEMBUAT MUNCUL SEBAGAI POP-UP!
        -->
    </record>
</odoo>