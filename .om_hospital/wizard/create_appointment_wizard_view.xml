<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <record id="view_create_appointment_wizard_form" model="ir.ui.view">
        <field name="name">create.appointment.wizard.form</field>
        <field name="model">create.appointment.wizard</field>
        <field name="arch" type="xml">
            <form string="Create New Appointment">
                <group>
                    <field name="date_appointment"/>
                    <field name="patient_id"/>
                    <field name="doctor_id"/>
                </group>
                <footer>
                    <button name="action_create_appointment" string="Create" type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_create_appointment" model="ir.actions.act_window">
        <field name="name">Create Appointment</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">create.appointment.wizard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_create_appointment_wizard_form"></field>
        <field name="target">new</field>
        <!-- 
            ⭐⭐⭐ Line 25: TARGET = NEW ⭐⭐⭐
            - "new" → BUKA SEBAGAI POP-UP / DIALOG
            - "current" → buka di halaman yang sama (replace)
            - "inline" → embed di halaman
            - "fullscreen" → buka fullscreen
            
            ✅ INI YANG MEMBUAT MUNCUL SEBAGAI POP-UP!
        -->
    </record>
</odoo>